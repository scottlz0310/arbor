# デフォルト: テキストファイルは自動判定し LF に正規化
* text=auto eol=lf

# Rust / Tauri
*.rs    text eol=lf
*.toml  text eol=lf
*.lock  text eol=lf

# Web フロントエンド
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# バイナリ扱い（変換禁止）
*.png   binary
*.jpg   binary
*.ico   binary
*.woff  binary
*.woff2 binary
